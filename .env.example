APP_NAME=MayWrites
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production: set APP_URL to your canonical HTTPS origin (scheme + host). Mismatched
# APP_URL vs the browser origin breaks session cookies and redirects (e.g. login loop).

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production HTTPS: SESSION_SECURE_COOKIE=true when the app is only served over TLS.
# SESSION_DRIVER=database (or redis) when you need sessions shared across multiple app servers.

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=usd
CASHIER_CURRENCY_LOCALE=en

# First subscription only: free trial before the first monthly charge (Stripe Checkout).
SUBSCRIPTION_TRIAL_ENABLED=true
SUBSCRIPTION_TRIAL_DAYS=7

# Optional: notify this address when OnboardCustomerJob exhausts retries (Trello still failing)
BILLING_ONBOARDING_FAILURE_EMAIL=

# Minutes shown on checkout success page for "contact support if no email" guidance
BILLING_CHECKOUT_FOLLOWUP_MINUTES=15

# true (default) = Trello board, invite, webhook on checkout (including trial)
# false = wait until first paid invoice / trialing → active
TRELLO_PROVISION_ON_CHECKOUT=true

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

TRELLO_API_KEY=
TRELLO_API_TOKEN=
TRELLO_TEMPLATE_BOARD_ID=
# Trello Workspace (Organization) ID from https://trello.com/w/{workspace}/ — not a board ID
TRELLO_WORKSPACE_ID=
TRELLO_WEBHOOK_SECRET=
# false (default) = lookup email in Workspace first; reuse board + Trello comment if found, else create board
# true = always create a new board and invite as billable multi-board guest (Workspace charge)
TRELLO_ALLOW_BILLABLE_GUEST=false
TRELLO_BOARD_NAME_SUFFIX="Writing Board"

APP_STORAGE_DISK=local
